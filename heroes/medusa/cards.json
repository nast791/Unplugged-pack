      {
        "id": "arrow_volley",
        "trigger": "during_combat",
        "conditions": {
          "all": [
            {
              "fact": "CARD_MATCHES_FIGHTER"
            },
            {
              "fact": "CARD_MATCHES_PHASE"
            },
            {
              "fact": "CARDS_IN_HAND",
              "check": {
                "var": "$candidates",
                "operator": "isNonEmpty"
              },
              "return": "$candidates"
            }
          ]
        },
        "actions": [
          {
            "id": "ask_apply",
            "type": "PROMPT",
            "return": "$answer",
