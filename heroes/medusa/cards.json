  {
    "id": "medusa_04",
    "title": "Зов стаи",
    "type": "hybrid",
    "value": 4,
    "bonus": 3,
    "quantity": 2,
    "fighter": "harpies",
    "phase": "after_combat",
    "text": "ПОСЛЕ БИТВЫ: Можете передвинуть каждую Гарпию на расстояние до 3 клеток.",
    "image": "m04.webp",
    "triggers": [
      {
        "id": "flock_call",
        "trigger": "after_combat",
        "conditions": {
          "all": [
            {
              "fact": "CARD_MATCHES_FIGHTER"
            },
            {
              "fact": "CARD_MATCHES_PHASE"
            },
            {
              "fact": "OWN_FIGHTERS",
              "params": {
                "group": "harpies"
              },
              "check": {
                "var": "$harpies",
                "operator": "isNonEmpty"
              },
              "return": "$harpies"
            }
          ]
        },
        "actions": [
          {
            "id": "ask_move",
            "type": "PROMPT",
            "return": "$answer",
            "conditions": {
              "all": [
                {
                  "var": "$answer",
                  "operator": "isEmpty"
                },
                {
                  "var": "$harpies",
                  "operator": "isNonEmpty"
                }
              ]
            },
            "params": {
              "message": "Будете передвигать гарпию на расстояние до 3 клеток?",
              "answers": [
                {
                  "id": "move",
                  "text": "Да",
                  "value": "move"
                },
                {
                  "id": "skip",
                  "text": "Нет",
                  "value": "skip"
                }
              ]
            },
            "start": true,
            "description": "Спросить: передвигать гарпий (до 3 клеток)?"
          },
          {
            "id": "finish_skip",
            "type": "LOG",
            "end": true,
            "conditions": {
              "all": [
                {
                  "var": "$answer",
                  "operator": "equal",
                  "value": "skip"
                }
              ]
            },
            "params": {
              "message": "Передвижение отменено"
            },
            "description": "Завершить — передвижение отменено"
          },
          {
            "id": "select_harpy",
            "type": "SELECT_TARGET",
            "return": "$harpyId",
            "conditions": {
              "all": [
                {
                  "var": "$answer",
                  "operator": "equal",
                  "value": "move"
                },
                {
                  "var": "$harpyId",
                  "operator": "isEmpty"
                }
              ]
            },
            "params": {
              "candidates": "$harpies",
              "selection": 1,
              "message": "Выберите гарпию для перемещения (осталось: ${remaining})"
            },
            "description": "Выбрать гарпию для перемещения"
          },
          {
            "id": "select_cell",
            "type": "SELECT_CELL",
            "return": "$moveCell",
            "conditions": {
              "all": [
                {
                  "var": "$answer",
                  "operator": "equal",
                  "value": "move"
                },
                {
                  "var": "$harpyId",
                  "operator": "isNonEmpty"
                },
                {
                  "var": "$moveCell",
                  "operator": "isEmpty"
                }
              ]
            },
            "params": {
              "fighterId": "$harpyId",
              "maxSteps": 3,
              "fromCurrent": true,
              "message": "Выберите клетку для перемещения"
            },
            "description": "Выбрать клетку назначения (до 3 шагов)"
          },
          {
            "id": "apply_move",
            "type": "MOVE_FIGHTER",
            "conditions": {
              "all": [
                {
                  "var": "$answer",
                  "operator": "equal",
                  "value": "move"
                },
                {
                  "var": "$harpyId",
                  "operator": "isNonEmpty"
                },
                {
                  "var": "$moveCell",
                  "operator": "isNonEmpty"
                }
              ]
            },
            "params": {
              "fighterId": "$harpyId",
              "cellId": "$moveCell",
              "maxSteps": 3,
              "fromCurrent": true,
              "removeFrom": "harpies"
            },
            "description": "Переместить гарпию на выбранную клетку"
          },
          {
            "id": "finish_done",
            "type": "LOG",
            "end": true,
            "conditions": {
              "all": [
                {
                  "var": "$harpies",
                  "operator": "isEmpty"
                }
              ]
            },
            "params": {
              "message": "Передвижение завершено"
            },
            "description": "Завершить — все гарпии передвинуты"
          },
          {
            "id": "loop",
            "type": "RELOOP_PIPELINE",
            "conditions": {
              "all": [
                {
                  "var": "$answer",
                  "operator": "equal",
                  "value": "move"
                },
                {
                  "var": "$harpies",
                  "operator": "isNonEmpty"
                },
                {
                  "var": "$moveCell",
                  "operator": "isNonEmpty"
                }
              ]
            },
            "params": {
              "steps": [
                "ask_move",
                "select_harpy",
                "select_cell",
                "apply_move"
              ],
              "clearVars": [
                "$answer",
                "$harpyId",
                "$moveCell"
              ]
            },
            "description": "Повторить цикл, если остались гарпии в очереди"
          }
        ]
      }
    ]
  },
