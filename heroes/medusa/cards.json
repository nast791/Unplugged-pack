              "all": [
                {
                  "var": "$answer",
                  "operator": "isEmpty"
                }
              ]
            },
            "params": {
              "message": "Прибавить бонусное значение другой карты к силе этой атаки?",
              "answers": [
                {
                  "id": "apply",
                  "text": "Да",
                  "value": "apply"
                },
                {
                  "id": "skip",
                  "text": "Нет",
                  "value": "skip"
                }
              ]
            },
            "start": true,
            "description": "Спросить: прибавить бонус другой карты к силе атаки?"
          },
          {
            "id": "pick_card",
            "type": "SELECT_CARDS",
            "return": "$bonusCard",
            "conditions": {
              "all": [
                {
                  "var": "$answer",
                  "operator": "equal",
                  "value": "apply"
                },
                {
                  "var": "$bonusCard",
                  "operator": "isEmpty"
                }
              ]
            },
            "params": {
              "candidates": "$candidates",
              "selection": 1
            },
            "description": "Выбрать карту из руки для бонуса"
          },
          {
            "id": "add_bonus",
            "type": "ADD_BONUS",
            "conditions": {
              "all": [
                {
                  "var": "$answer",
                  "operator": "equal",
                  "value": "apply"
                },
                {
                  "var": "$bonusCard",
                  "operator": "isNonEmpty"
                }
              ]
            },
            "params": {
              "cardId": "$bonusCard"
            },
            "description": "Прибавить бонус выбранной карты к силе атаки"
          },
          {
            "id": "move_bonus_to_discard",
            "type": "MOVE_CARDS",
            "end": true,
            "conditions": {
              "all": [
                {
                  "var": "$answer",
                  "operator": "equal",
                  "value": "apply"
                },
                {
                  "var": "$bonusCard",
                  "operator": "isNonEmpty"
                }
              ]
            },
            "params": {
              "from": "hand",
              "targets": "$bonusCard",
              "count": 1,
              "to": "discard"
